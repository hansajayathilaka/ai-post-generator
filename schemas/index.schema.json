{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "index.schema.json",
  "title": "Posts Index",
  "description": "Schema for posts/index.json — ordered array of all post metadata, newest first.",
  "type": "array",
  "items": { "$ref": "#/definitions/PostEntry" },
  "definitions": {
    "PostEntry": {
      "type": "object",
      "required": ["id", "title", "slug", "created_at", "author", "tags", "excerpt"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}-.+$"
        },
        "title":      { "type": "string", "minLength": 1 },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "author":     { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "excerpt":    { "type": "string", "minLength": 1 },
        "hero_image": { "type": ["string", "null"] }
      }
    }
  }
}
