{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "meta.schema.json",
  "title": "Post Metadata",
  "description": "Schema for posts/{id}/meta.json — one file per post.",
  "type": "object",
  "required": ["id", "title", "slug", "created_at", "author", "tags", "excerpt"],
  "additionalProperties": false,
  "properties": {
    "$schema":   { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-.+$",
      "description": "YYYY-MM-DD-slug, must match the post directory name."
    },
    "title":      { "type": "string", "minLength": 1 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "URL-safe, lowercase, hyphen-separated."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime with timezone offset."
    },
    "author":     { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "excerpt":    { "type": "string", "minLength": 1 },
    "hero_image": { "type": ["string", "null"] }
  }
}
