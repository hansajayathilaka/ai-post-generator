---
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";
import { marked } from "marked";
import PostLayout from "../../layouts/PostLayout.astro";
import posts from "../../../posts/index.json";

export function getStaticPaths() {
  return posts.map((post) => ({ params: { id: post.id } }));
}

const { id } = Astro.params;
const meta = posts.find((p) => p.id === id)!;

const postDir = resolve("posts", id);
const markdown = readFileSync(resolve(postDir, "post.md"), "utf-8");
const html = marked(markdown) as string;

// Load sources.json if present (AI-generated posts only)
type Source = { title: string; url: string };
let sources: Source[] = [];
const sourcesPath = resolve(postDir, "sources.json");
if (existsSync(sourcesPath)) {
  sources = JSON.parse(readFileSync(sourcesPath, "utf-8")) as Source[];
}
---

<PostLayout
  title={meta.title}
  created_at={meta.created_at}
  author={meta.author}
  excerpt={meta.excerpt}
  tags={meta.tags}
  hero_image={meta.hero_image}
  postId={id}
>
  <div set:html={html} />

  {sources.length > 0 && (
    <div class="sources">
      <h2>Sources</h2>
      <ol>
        {sources.slice(0, 5).map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer">
              {s.title || s.url}
            </a>
          </li>
        ))}
      </ol>
      {sources.length > 5 && (
        <>
          <ol id="sources-extra" class="sources-extra" start={6}>
            {sources.slice(5).map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer">
                  {s.title || s.url}
                </a>
              </li>
            ))}
          </ol>
          <button id="sources-toggle" class="sources-toggle">
            See {sources.length - 5} more
          </button>
        </>
      )}
    </div>
  )}
</PostLayout>

<style>
  .sources {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .sources h2 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 0.875rem;
  }

  .sources ol {
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sources li {
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .sources a {
    color: var(--color-text-muted);
    text-decoration: none;
    word-break: break-word;
    transition: color 0.15s;
  }

  .sources a:hover {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .sources-extra {
    display: none;
  }

  .sources-extra.open {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .sources-toggle {
    margin-top: 0.5rem;
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8rem;
    color: var(--color-primary);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

<script>
  const toggle = document.getElementById("sources-toggle");
  const extra = document.getElementById("sources-extra");
  if (toggle && extra) {
    const moreCount = extra.querySelectorAll("li").length;
    toggle.addEventListener("click", () => {
      const isOpen = extra.classList.toggle("open");
      toggle.textContent = isOpen ? "See less" : `See ${moreCount} more`;
    });
  }
</script>
